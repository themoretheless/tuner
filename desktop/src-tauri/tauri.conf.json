{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Guitar Tuner",
  "version": "0.1.0",
  "identifier": "com.tuner.guitar",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Guitar Tuner",
        "width": 720,
        "height": 640,
        "minWidth": 520,
        "minHeight": 580,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5173 http://127.0.0.1:5173 ws://localhost:5173 ws://127.0.0.1:5173; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; media-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 Guitar Tuner",
    "category": "Music",
    "shortDescription": "Accurate guitar tuner for desktop",
    "longDescription": "Professional guitar tuner application. Detects pitch in real time using advanced algorithms. Supports multiple tunings, reference tones, and works completely offline.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": ["en-US", "ru-RU"]
      },
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English", "Russian"]
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": [],
        "desktopTemplate": null
      },
      "appimage": {
        "bundleMediaFramework": false
      },
      "rpm": {
        "depends": []
      }
    }
  }
}
